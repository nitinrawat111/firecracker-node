{
  "name": "firecracker-node",
  "version": "0.0.1",
  "description": "A typesafe-api interface for Firecracker micro VMs",
  "scripts": {
    "compile": "tsc",
    "gen:docs": "typedoc",
    "lint": "eslint . --fix",
    "pretty": "prettier --write .",
    "prepare": "husky",
    "start:firecracker": "rm /tmp/firecracker.socket && firecracker --api-sock /tmp/firecracker.socket"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.3",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "prettier": "^3.7.4",
    "typedoc": "^0.28.15",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1"
  },
  "dependencies": {
    "undici": "^7.16.0"
  }
}
